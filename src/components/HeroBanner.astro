<style>

  .hero-container {
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    padding: 0;
    background-color: var(--dark-bg);
    overflow: hidden;
    overflow-y: hidden;
  }

  /* --- Gestion de l'image de fond --- */
  .hero-visual {
    position: absolute;
    inset: 0; /* Prend tout l'espace */
    z-index: 1;
    opacity: 0; /* Initialement caché pour GSAP */
    display: flex;
    justify-content: end;
  }

  .full-bg-image {
    width: 65vw;
    height: 100%;
    object-fit: cover;
    object-position: 75% 25%;
  }

  .overlay {
    position: absolute;
    inset: 0;
  }

  /* Dégradé de gauche à droite (noir vers transparent) */
  .layer-horizontal {
    background: linear-gradient(
      to right,
      var(--dark-bg) 10%,
      rgba(15, 23, 42, 0.9) 40%,
      rgba(15, 23, 42, 0.4) 80%,
      transparent 100%
    );
  }

  /* Dégradé du bas vers le haut pour adoucir les bords */
  .layer-vertical {
    background: linear-gradient(
      to top,
      var(--dark-bg) 0%,
      transparent 50%,
      rgba(15, 23, 42, 0.5) 100%
    );
  }

  /* --- Contenu --- */
  .hero-content {
    position: relative;
    z-index: 2; /* Doit être au dessus de l'image */
    max-width: 700px;
    left: 10%;
    opacity: 0; /* Caché pour l'anim */
    transform: translateX(-50px);
  }

  .hero-name {
    font-size: clamp(3rem, 10vw, 5rem);
    font-weight: 400;
    color: var(--text-white);
    margin: 0;
    line-height: 1;
  }

  .accent {
    background: linear-gradient(
      135deg, 
      var(--primary-blue) -10%, 
      var(--primary-orange) 110%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: "Story Script", sans-serif;
    font-weight: 400;
    font-style: normal;
  }

  .hero-job {
    font-size: 1.25rem;
    margin-top: 1rem;
    font-weight: 400;
    letter-spacing: 2px;
    background: linear-gradient(
      135deg, 
      var(--primary-blue) -10%, 
      var(--primary-orange) 110%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-divider {
    height: 3px;
    width: 50%;
    background: linear-gradient(
      135deg, 
      var(--primary-blue) 0%, 
      var(--primary-orange) 150%
    );
    margin-top: 2rem;
    box-shadow: 0 0 15px var(--primary-blue);
    transform-origin: left;
    transform: scaleX(0); /* Caché pour l'anim */
  }

  .hero-footer {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: center;
    margin-top: 2rem;
  }

  .hero-footer a svg {
    fill: var(--text-dim);
  }

  .hero-footer a:hover svg {
    fill: var(--primary-blue);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-container {
      justify-content: center;
      text-align: center;
    }
    .hero-divider {
      margin: 2rem auto 0;
    }
    .layer-horizontal {
        background: rgba(15, 23, 42, 0.7); /* Plus sombre sur mobile pour la lisibilité */
    }
    .hero-content {
      left: 0%;
    }

    .full-bg-image {
      width: 100vw;
      height: 100%;
      object-fit: cover;
      object-position: 75% 25%;
    }

    .hero-footer {
      justify-content: center;
    }
  }
</style>

<script>
  import gsap from "gsap";

  const animateHero = () => {
    const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.2 } });

    tl.to(".hero-visual", { opacity: 1, duration: 2 })
      .to(".hero-content", { opacity: 1, x: 0 }, "-=1.5")
      .to(".hero-divider", { scaleX: 1 }, "-=1");
  };

  // Gestion du chargement Astro
  document.addEventListener('DOMContentLoaded', animateHero);
  document.addEventListener('astro:after-swap', animateHero);
</script>